# =============================================================================
# DIFF & MERGE TOOLS
# =============================================================================
{{ if eq .machine.role "workstation" }}
[delta]
    navigate = true
    side-by-side = true
    syntax-theme = "DarkNeon"
    plus-style = "syntax #445345"
    minus-style = "syntax #4F221F"
    line-numbers = true

[interactive]
    diffFilter = delta --color-only

[diff]
    colorMoved = default
    external = difft
    tool = difftastic

[difftool]
    prompt = false

[difftool "difftastic"]
    cmd = difft "$MERGED" "$LOCAL" "abcdef1" "100644" "$REMOTE" "abcdef2" "100644"
{{ end }}

[merge]
    conflictstyle = zdiff3

[apply]
    whitespace = fix

# =============================================================================
# BRANCH MANAGEMENT
# =============================================================================
[branch]
    sort = -committerdate

# =============================================================================
# COLOR SETTINGS
# =============================================================================
[color]
    ui = true

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

# =============================================================================
# REMOTE OPERATIONS
# =============================================================================
[fetch]
    prune = true      # Remove deleted remote branches in local
    pruneTags = true  # Remove deleted remote tags in local
    all = true        # Fetch from all configured remotes

[push]
    # agar ketika membuat branch baru di local tidak perlu melakukan perintah 'git push --set-upstream origin nama-branch-baru' . Menghindari salah penulisan nama branch sehingga dapat menyebabkan nama branch di local dan remote berbeda
    default = current

[pull]
    # avoid accidentally creating a merge commit when you run git pull on a branch where the upstream branch has diverged
    rebase = true

# =============================================================================
# REBASE SETTINGS
# =============================================================================
[rebase]
    autosquash = true
    autostash = true
    updateRefs = true

# =============================================================================
# PAGER SETTINGS
# =============================================================================
[pager]
    status = true
    show-branch = true
    {{ if eq .machine.role "workstation" }}
    difftool = true
    {{ end }}

# =============================================================================
# LFS (Large File Storage)
# =============================================================================
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
