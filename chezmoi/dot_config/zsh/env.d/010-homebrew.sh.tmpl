{{ if eq .chezmoi.os "darwin" }}
# Homebrew - Environment Variable

# This block below mirrors `eval "$(/opt/homebrew/bin/brew shellenv)"`,
# but kept static to avoid startup cost.
export HOMEBREW_PREFIX="{{ .shell_env.homebrew.prefix }}"
export HOMEBREW_CELLAR="{{ .shell_env.homebrew.cellar }}"
export HOMEBREW_REPOSITORY="{{ .shell_env.homebrew.repository }}"

if [[ -d "{{ index .shell_env.homebrew.bin_paths 0 }}" ]]; then
  case ":$PATH:" in
    *":{{ index .shell_env.homebrew.bin_paths 0 }}:"*) ;;
    *) PATH="{{ index .shell_env.homebrew.bin_paths 0 }}:$PATH" ;;
  esac
fi

if [[ -d "{{ index .shell_env.homebrew.bin_paths 1 }}" ]]; then
  case ":$PATH:" in
    *":{{ index .shell_env.homebrew.bin_paths 1 }}:"*) ;;
    *) PATH="{{ index .shell_env.homebrew.bin_paths 1 }}:$PATH" ;;
  esac
fi

export PATH

if [[ -n "${MANPATH:-}" ]]; then
  export MANPATH=":$MANPATH"
fi

if [[ ":${INFOPATH:-}:" != *":{{ .shell_env.homebrew.info_path }}:"* ]]; then
  export INFOPATH="{{ .shell_env.homebrew.info_path }}${INFOPATH:+:$INFOPATH}"
fi
{{ end }}
