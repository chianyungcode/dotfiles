# == CONFIGURATION ENV VARIABLE ===
export DOTFILES="$HOME/.local/share/chezmoi"
export EDITOR="{{ .shell_env.common.EDITOR }}"
export LM_STUDIO_BIN="{{ .shell_env.common.LM_STUDIO_BIN }}"
export TMUXIFIER_LAYOUT_PATH="{{ .shell_env.common.TMUXIFIER_LAYOUT_PATH }}"
export ANTIDOTE_HOME="${XDG_CACHE_HOME}/antidote"

# Let zsh-abbr leave the cursor at the end of the expanded text
export ABBR_SET_EXPANSION_CURSOR=1

# Enable multiple-cursor placeholder support in zsh-abbr
# (required if you use more than one “cursor stop” in an abbreviation)
export ABBR_SET_LINE_CURSOR=1

# --- Configuration ---
export GIT_CONFIG_GLOBAL="{{ .shell_env.common.GIT_CONFIG_GLOBAL }}"
export PROTO_HOME="{{ .shell_env.common.PROTO_HOME }}"
export STARSHIP_CONFIG="{{ .shell_env.common.STARSHIP_CONFIG }}"
export PARALLEL_HOME="{{ .shell_env.common.PARALLEL_HOME }}"
export SCREENRC="{{ .shell_env.common.SCREENRC }}"
export WGETRC="{{ .shell_env.common.WGETRC }}"

# --- Data ---
export _ZO_DATA_DIR="{{ .shell_env.common._ZO_DATA_DIR }}"

{{ if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "arch") -}}
export HYPRLAND_CONFIG="{{ .shell_env.arch_linux.HYPRLAND_CONFIG }}"
export TERMINFO="{{ .shell_env.arch_linux.TERMINFO }}"
export TERMINFO_DIRS="{{ .shell_env.arch_linux.TERMINFO_DIRS }}"
{{ end -}}

# --- State & Misc ---
export LESSHISTFILE="${LESSHISTFILE:-{{ .shell_env.common.LESSHISTFILE }}}"
export PYTHON_HISTORY="{{ .shell_env.common.PYTHON_HISTORY }}"

if [[ -z "${SSH_TTY:-}" ]]; then
  {{- if eq .chezmoi.os "darwin" }}
  export SSH_AUTH_SOCK="{{ .shell_env.ssh_auth_sock.darwin }}"
  {{- else if eq .chezmoi.os "linux" }}
  export SSH_AUTH_SOCK="{{ .shell_env.ssh_auth_sock.linux }}"
  {{- end }}
fi

{{ if eq .chezmoi.os "darwin" }}
export DISABLE_AUTO_TITLE='true' # Prevent auto update in title window macos
{{ end }}
