{{ if eq .chezmoi.os "darwin" }}
# Keep Homebrew binaries first even in non-login interactive shells.
if test -d /opt/homebrew/bin
    fish_add_path -g --move --path "/opt/homebrew/bin" "/opt/homebrew/sbin"
end
{{ end }}

status --is-login; or return
if set -q __fish_login_env_loaded
    return
end
set -g __fish_login_env_loaded 1
set -l __fish_config_home "$HOME/.config"
if set -q XDG_CONFIG_HOME
    set __fish_config_home "$XDG_CONFIG_HOME"
end
set -l __fish_env_dir "$__fish_config_home/fish/env.d"

for f in $__fish_env_dir/*.fish
    test -f "$f"; or continue
    source "$f"
end
