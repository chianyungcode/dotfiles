{{ if eq .secrets.provider "onepassword" -}}
{{ $context7 := onepasswordRead .secrets.ai_tools.context7_apikey -}}
{{- if $context7 -}}
set -gx CONTEXT7_MCP_API_KEY "{{ $context7 }}"
{{ end -}}
{{- $github := "" -}}
{{- if .identity.github_token -}}
{{- $github = onepasswordRead (index .secrets.github .identity.github_token) -}}
{{- end -}}
{{- if $github -}}
set -gx GITHUB_TOKEN "{{ $github }}"
{{ end -}}
{{ $openrouter := onepasswordRead .secrets.ai_tools.opencode_apikey -}}
{{- if $openrouter -}}
set -gx OPENROUTER_OPENCODE_APIKEY "{{ $openrouter }}"
{{ end -}}
{{ $wakatime := onepasswordRead .secrets.productivity.wakatime_apikey -}}
{{- if $wakatime -}}
set -gx WAKATIME_API_KEY "{{ $wakatime }}"
{{- end -}}
{{- end }}
